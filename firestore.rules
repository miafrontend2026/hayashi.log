rules_version = '2';

// Firestore security rules for jpnote-1bdd6
//
// 部署方式（選一）：
//   A. Firebase Console → Firestore Database → Rules → 貼上此檔內容 → 發布
//   B. Firebase CLI: `firebase deploy --only firestore:rules`
//      （需先 `firebase init firestore` 關聯 project jpnote-1bdd6）

service cloud.firestore {
  match /databases/{database}/documents {

    // 使用者私人資料（收藏 / 學習進度 / 複習資料 / 訂閱狀態）
    // 結構：users/{uid} → { favorites, quiz_history, srs_data, subscription, ... }
    // owner 可讀寫自己;admin email 可讀(report / debug 用,不能寫)
    match /users/{userId} {
      allow read: if request.auth != null && (
                    request.auth.uid == userId ||
                    request.auth.token.email in ['stayjpplan@gmail.com', 'abc83327@gmail.com']
                  );
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 訂閱交易帳本 — Cloud Function 寫,admin + 用戶自己讀
    // 結構:transactions/{txnId} → { uid, type, amount_twd, ... }
    match /transactions/{txnId} {
      allow read: if request.auth != null && (
                    request.auth.token.email in ['stayjpplan@gmail.com', 'abc83327@gmail.com'] ||
                    resource.data.uid == request.auth.uid
                  );
      allow write: if false;  // 只有 Cloud Function (Admin SDK) 能寫
    }

    // 早鳥計數器
    match /counters/{name} {
      allow read: if true;  // 前端 paywall 要顯示「剩 X 名」
      allow write: if false;  // 只 Cloud Function 寫
    }

    // 黑名單(退費 / chargeback 紀錄)— 用 emailHash 當 doc id
    // 只有 Cloud Function 能讀寫;前端不該知道誰在黑名單
    match /blacklist/{emailHash} {
      allow read: if request.auth != null &&
                     request.auth.token.email in ['stayjpplan@gmail.com', 'abc83327@gmail.com'];
      allow write: if false;
    }

    // 意見回饋 — contact.html 表單寫入,admin.html 後台讀寫
    // 創建:登入用戶寫自己的(防偽造)
    // 讀/改/刪:僅 owner email = stayjpplan@gmail.com 或 abc83327@gmail.com
    match /feedback/{docId} {
      allow read, update, delete: if
        request.auth != null &&
        request.auth.token.email in ['stayjpplan@gmail.com', 'abc83327@gmail.com'];
      allow create: if
        request.auth != null &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.keys().hasAll(['type', 'message', 'uid', 'createdAt']) &&
        request.resource.data.type in ['bug', 'feature', 'content', 'other'] &&
        request.resource.data.message is string &&
        request.resource.data.message.size() > 0 &&
        request.resource.data.message.size() <= 5000;
    }

    // 訪客 streak 雲端備份（已登入用戶）— 結構併入 users/{uid}.streak，不需要獨立規則

    // 公開累積計數器 — home.html 顯示「已有 X 位學員」
    // 客戶端 +1 已停用（吃 Spark 20K 寫/日上限），改由 GitHub Actions cron 用
    // service account 覆寫；前端只讀。SA Admin 寫入會繞過這條 rule。
    match /stats/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // 學習內容主檔 — vocab / grammar / listening / reading / confusables 集中。
    // 前端 + App 都讀同一份；寫入限 SA（migration script 用 JWT）。
    match /content/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // 預設拒絕：未明確允許的所有路徑皆擋
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
